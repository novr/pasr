{
  "name": "pasr",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --test-scheduled --port 8787 --persist-to=./.wrangler/state",
    "db:migrate:local": "wrangler d1 migrations apply pasr-db --local",
    "debug:mention-ai": "node --experimental-strip-types scripts/debug-mention-ai.ts",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "PASR_RUN_INTEGRATION=1 vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "PASR_RUN_INTEGRATION=1 vitest --config vitest.integration.config.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "typescript": "^5.9.2",
    "vitest": "^4.1.9",
    "wrangler": "^4.21.1"
  }
}
