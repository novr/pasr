# Copy to .dev.vars for local `npm run dev`, `npm run types`, and integration tests.
# Restart `npm run dev` after editing.

SLACK_BOT_TOKEN=replace-with-bot-token
SLACK_SIGNING_SECRET=replace-with-signing-secret
RUN_ENDPOINT_TOKEN=replace-with-local-token
DEBUG_ENDPOINTS_ENABLED=false
SLACK_ADMIN_USER_IDS=U_REPLACE_WITH_ADMIN_USER_ID
SLACK_PASR_USERS_USERGROUP_ID=
PASR_NOTIFY_EMPTY_DEFAULT=true
SLACK_PASR_OPS_CHANNEL=
SLACK_PASR_NOTICE_CH=

# Slack User OAuth (Status sync). Optional — unset disables OAuth UI and status sync.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_OAUTH_ENCRYPTION_KEY=
PASR_PUBLIC_BASE_URL=
PASR_STATUS_DEFAULT_TEXT=不在
PASR_STATUS_EMOJI=:date:
